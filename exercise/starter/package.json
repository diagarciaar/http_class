    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^10.0.0",
    "jsdom": "^28.0.0",
    "json-server": "^0.17.4",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
